PORT=5001
NODE_ENV=development

# Pinata IPFS credentials – get from https://app.pinata.cloud/keys
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key
PINATA_JWT=your_pinata_jwt_token

# Deployed contract address (fill after deploying)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Polygon Amoy RPC
POLYGON_RPC_URL=https://polygon-amoy.infura.io/v3/your_infura_project_id
CHAIN_ID=80002

# Optional: MongoDB for metadata caching
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/synergy-vault

# Supabase duplicate-protection store
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OCR_RESERVATION_TTL_MINUTES=15
BACKEND_AUTH_SECRET=change_me_to_a_random_secret
ADMIN_WALLET_ADDRESSES=0xYourAdminWalletOne,0xYourAdminWalletTwo

# Google Vision credentials for OCR duplicate detection
GOOGLE_VISION_CREDENTIALS_PATH=../vision.json

# CORS – set to your frontend URL in production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
